<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Crash - GexBet</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/games.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">🎰 GexBet</a>
      <div class="nav-links">
        <span class="coins">💰 <span id="balanceDisplay"><%= user.coins.toFixed(2) %></span> coins</span>
        <span class="username"><%= user.username %></span>
        <a href="/games" class="btn-back">Voltar</a>
      </div>
    </div>
  </nav>

  <div class="game-container">
    <div class="game-header">
      <h1>✈️ Crash</h1>
      <% if (user.is_demo) { %>
        <div class="demo-badge">🎬 CONTA DEMO - SEMPRE GANHA!</div>
      <% } %>
    </div>

    <div class="crash-screen">
      <div class="crash-canvas-container">
        <div class="multiplier-display" id="multiplierDisplay">1.00x</div>
        <canvas id="crashCanvas" width="600" height="400"></canvas>
      </div>
    </div>

    <div class="game-controls">
      <div class="bet-control">
        <label>Aposta:</label>
        <div class="bet-input-group">
          <button onclick="changeBet(-1)">-</button>
          <input type="number" id="betAmount" value="1" min="1" step="1">
          <button onclick="changeBet(1)">+</button>
        </div>
      </div>
      <div class="bet-control">
        <label>Multiplicador alvo:</label>
        <input type="number" id="cashoutAt" value="2.0" min="1.1" step="0.1" class="small-input">
      </div>
      <button onclick="playCrash()" class="btn-spin" id="spinBtn">✈️ APOSTAR</button>
    </div>

    <div class="game-result" id="gameResult"></div>
  </div>

  <script src="/js/games/crash.js"></script>
</body>
</html>
