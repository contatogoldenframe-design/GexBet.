<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Caça Níqueis - GexBet</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="/css/games.css">
</head>
<body>
  <nav class="navbar">
    <div class="container">
      <a href="/" class="logo">🎰 GexBet</a>
      <div class="nav-links">
        <span class="coins">💰 <span id="balanceDisplay"><%= user.coins.toFixed(2) %></span> coins</span>
        <span class="username"><%= user.username %></span>
        <a href="/games" class="btn-back">Voltar</a>
      </div>
    </div>
  </nav>

  <div class="game-container">
    <div class="game-header">
      <h1>🎰 Caça Níqueis</h1>
      <% if (user.is_demo) { %>
        <div class="demo-badge">🎬 CONTA DEMO - SEMPRE GANHA!</div>
      <% } %>
    </div>

    <div class="slots-machine">
      <div class="slot-reel" id="reel0">🍒</div>
      <div class="slot-reel" id="reel1">🍋</div>
      <div class="slot-reel" id="reel2">🍊</div>
      <div class="slot-reel" id="reel3">🍇</div>
      <div class="slot-reel" id="reel4">🔔</div>
    </div>

    <div class="game-controls">
      <div class="bet-control">
        <label>Valor:</label>
        <div class="bet-input-group">
          <button onclick="changeBet(-1)">-</button>
          <input type="number" id="betAmount" value="1" min="1" step="1">
          <button onclick="changeBet(1)">+</button>
        </div>
      </div>
      <button onclick="playSlots()" class="btn-spin" id="spinBtn">🎰 GIRAR</button>
    </div>

    <div class="game-result" id="gameResult"></div>
  </div>

  <script src="/js/games/slots.js"></script>
</body>
</html>
